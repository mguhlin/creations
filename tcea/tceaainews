<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI-Powered Newsletter Architecture for Educators | TCEA Lunch &amp; Learn</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #0A3476;
    --navy-dark: #071f4a;
    --navy-mid: #12428f;
    --gold: #FCB040;
    --gold-light: #fdd17a;
    --gold-pale: #FEF0D0;
    --pale-navy: #D0D8F0;
    --white: #ffffff;
    --off-white: #f7f8fc;
    --text: #1a1a2e;
    --text-muted: #5a6680;
    --border: #e2e7f5;
    --teal: #0e6b8a;
    --sidebar-w: 240px;
    --topbar-h: 52px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    color: var(--text);
    background: var(--white);
    line-height: 1.6;
  }

  /* ═══════════════════════════════
     MOBILE TOP BAR
  ═══════════════════════════════ */
  .topbar {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--topbar-h);
    background: var(--navy-dark);
    border-bottom: 3px solid var(--gold);
    z-index: 200;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.25rem;
  }
  .topbar-brand {
    font-family: 'DM Serif Display', serif;
    color: var(--gold); font-size: 0.92rem;
  }
  .topbar-brand span { color: var(--white); }

  .hamburger {
    background: none; border: none; cursor: pointer;
    display: flex; flex-direction: column; gap: 5px; padding: 6px;
  }
  .hamburger span {
    display: block; width: 22px; height: 2px;
    background: var(--gold); border-radius: 2px; transition: all 0.25s;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ═══════════════════════════════
     LEFT SIDEBAR
  ═══════════════════════════════ */
  .sidebar {
    position: fixed;
    top: 0; left: 0;
    width: var(--sidebar-w);
    height: 100vh;
    background: var(--navy-dark);
    border-right: 3px solid var(--gold);
    display: flex; flex-direction: column;
    z-index: 150;
    overflow-y: auto;
    transition: transform 0.3s ease;
  }

  .sidebar-header {
    padding: 1.4rem 1.2rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    flex-shrink: 0;
  }
  .sidebar-logo {
    font-family: 'DM Serif Display', serif;
    color: var(--gold); font-size: 1rem; line-height: 1.3; margin-bottom: 0.3rem;
  }
  .sidebar-logo span { color: var(--white); display: block; font-size: 0.78rem; }
  .sidebar-date {
    display: inline-block;
    background: var(--gold); color: var(--navy-dark);
    font-size: 0.62rem; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; padding: 0.2rem 0.6rem;
    border-radius: 100px; margin-top: 0.5rem;
  }

  .sidebar-nav { flex: 1; padding: 0.75rem 0; overflow-y: auto; }

  .nav-group-label {
    font-size: 0.58rem; font-weight: 700; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--text-muted);
    padding: 0.85rem 1.2rem 0.25rem;
  }

  .sidebar-nav a {
    display: flex; align-items: center; gap: 0.6rem;
    color: var(--pale-navy); text-decoration: none;
    font-size: 0.82rem; font-weight: 500;
    padding: 0.52rem 1.2rem;
    border-left: 3px solid transparent;
    transition: background 0.18s, color 0.18s, border-color 0.18s;
    line-height: 1.3;
  }
  .sidebar-nav a:hover,
  .sidebar-nav a.active {
    background: rgba(252,176,64,0.1);
    color: var(--gold); border-left-color: var(--gold);
  }
  .nav-icon { font-size: 0.9rem; flex-shrink: 0; width: 18px; text-align: center; }

  .sidebar-footer {
    padding: 0.9rem 1.2rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    font-size: 0.7rem; color: var(--text-muted); line-height: 1.65;
    flex-shrink: 0;
  }
  .sidebar-footer strong { color: var(--pale-navy); display: block; margin-bottom: 0.15rem; }
  .sidebar-footer a { color: var(--gold-light); text-decoration: none; }
  .sidebar-footer a:hover { text-decoration: underline; }

  /* Overlay */
  .sidebar-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,0.55); z-index: 140;
  }
  .sidebar-overlay.visible { display: block; }

  /* ═══════════════════════════════
     MAIN CONTENT AREA
  ═══════════════════════════════ */
  .main { margin-left: var(--sidebar-w); min-height: 100vh; }

  /* ── HERO ── */
  #hero {
    background: radial-gradient(ellipse at 20% 60%, rgba(252,176,64,0.12) 0%, transparent 60%),
                linear-gradient(150deg, var(--navy-dark) 0%, var(--navy) 60%, var(--navy-mid) 100%);
    color: var(--white);
    padding: 4.5rem 3rem 3.5rem;
    position: relative; overflow: hidden;
  }
  #hero::before {
    content: ''; position: absolute; inset: 0;
    background-image:
      repeating-linear-gradient(90deg, rgba(255,255,255,0.025) 0px, rgba(255,255,255,0.025) 1px, transparent 1px, transparent 60px),
      repeating-linear-gradient(0deg,  rgba(255,255,255,0.025) 0px, rgba(255,255,255,0.025) 1px, transparent 1px, transparent 60px);
  }
  .hero-badge {
    display: inline-block; background: var(--gold); color: var(--navy-dark);
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; padding: 0.28rem 0.85rem;
    border-radius: 100px; margin-bottom: 1.2rem; position: relative;
  }
  #hero h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.85rem, 3.8vw, 3rem); line-height: 1.15;
    max-width: 680px; margin-bottom: 1rem; position: relative;
  }
  #hero h1 em { color: var(--gold); font-style: italic; }
  .hero-sub {
    font-size: 0.98rem; color: var(--pale-navy);
    max-width: 540px; margin-bottom: 1.75rem; position: relative; line-height: 1.7;
  }
  .hero-meta {
    display: flex; flex-wrap: wrap; gap: 0.75rem 1.75rem;
    font-size: 0.82rem; color: var(--gold-light); position: relative;
  }
  .hero-meta span { display: flex; align-items: center; gap: 0.4rem; }
  .hero-stat-row {
    display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 2.25rem; position: relative;
  }
  .hero-stat {
    background: rgba(255,255,255,0.07); border: 1px solid rgba(252,176,64,0.25);
    border-radius: 10px; padding: 0.95rem 1.4rem; text-align: center; min-width: 120px;
  }
  .hero-stat .num {
    font-family: 'DM Serif Display', serif; font-size: 1.9rem;
    color: var(--gold); display: block; line-height: 1.1;
  }
  .hero-stat .label {
    font-size: 0.7rem; color: var(--pale-navy);
    text-transform: uppercase; letter-spacing: 0.07em; margin-top: 0.2rem;
    display: block; line-height: 1.4;
  }

  /* ── CONTENT SECTIONS ── */
  .cs { padding: 3.25rem 3rem; border-bottom: 1px solid var(--border); }
  .cs.alt  { background: var(--off-white); }
  .cs.dark { background: var(--navy-dark); color: var(--white); border-bottom-color: rgba(255,255,255,0.08); }

  .sec-eyebrow {
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--gold); display: block; margin-bottom: 0.35rem;
  }
  .cs.dark .sec-eyebrow { color: var(--gold-light); }

  h2.sec-title {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.45rem, 3vw, 2rem); color: var(--navy); margin-bottom: 0.3rem;
  }
  .cs.dark h2.sec-title { color: var(--gold); }

  .divider { width: 42px; height: 4px; background: var(--gold); border-radius: 2px; margin: 0.55rem 0 1.2rem; }

  .sec-lead {
    font-size: 0.97rem; color: var(--text-muted); max-width: 680px; margin-bottom: 1.75rem; line-height: 1.7;
  }
  .cs.dark .sec-lead { color: var(--pale-navy); }

  /* ── CARD GRID ── */
  .card-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.2rem; margin-top: 1.25rem;
  }
  .card {
    background: var(--white); border: 1.5px solid var(--border); border-radius: 12px;
    padding: 1.5rem; position: relative; transition: box-shadow 0.25s, transform 0.22s;
  }
  .card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0;
    height: 4px; background: var(--gold); border-radius: 12px 12px 0 0;
  }
  .card:hover { box-shadow: 0 6px 22px rgba(10,52,118,0.1); transform: translateY(-2px); }
  .card-num {
    font-family: 'DM Serif Display', serif; font-size: 2.4rem;
    color: var(--pale-navy); line-height: 1; margin-bottom: 0.35rem;
  }
  .card h3 { font-family: 'DM Serif Display', serif; font-size: 1.1rem; color: var(--navy); margin-bottom: 0.35rem; }
  .card h4 { font-family: 'DM Serif Display', serif; font-size: 1rem; color: var(--navy); margin-bottom: 0.3rem; }
  .card p  { font-size: 0.86rem; color: var(--text-muted); line-height: 1.65; margin-bottom: 0.8rem; }
  .tool-icon {
    width: 36px; height: 36px; background: var(--navy); border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 0.7rem; font-size: 0.95rem;
  }
  .tag-row { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .tag {
    font-size: 0.66rem; font-weight: 600; background: var(--gold-pale); color: var(--navy);
    border: 1px solid var(--gold-light); border-radius: 100px; padding: 0.16rem 0.55rem;
  }

  /* dark cards */
  .dark-card {
    background: rgba(255,255,255,0.07); border: 1px solid rgba(252,176,64,0.25);
    border-radius: 12px; padding: 1.5rem; text-align: center; transition: background 0.2s;
  }
  .dark-card:hover { background: rgba(255,255,255,0.12); }
  .dark-card .dc-num {
    font-family: 'DM Serif Display', serif; font-size: 2.4rem;
    color: var(--gold); display: block; margin-bottom: 0.35rem;
  }
  .dark-card h3 { font-family: 'DM Serif Display', serif; color: var(--white); font-size: 1rem; margin-bottom: 0.35rem; }
  .dark-card p  { font-size: 0.84rem; color: var(--pale-navy); line-height: 1.6; }

  /* ── WORKFLOW ── */
  .workflow-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 0; border: 1.5px solid var(--border); border-radius: 12px;
    overflow: hidden; margin-top: 1.5rem;
  }
  .wf-step {
    padding: 1.5rem 1.35rem; border-right: 1.5px solid var(--border);
    background: var(--white); transition: background 0.2s;
  }
  .wf-step:last-child { border-right: none; }
  .wf-step:hover { background: var(--gold-pale); }
  .wf-time {
    display: inline-block; background: var(--navy); color: var(--gold);
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.18rem 0.52rem; border-radius: 4px; margin-bottom: 0.6rem;
  }
  .wf-step h3 { font-family: 'DM Serif Display', serif; font-size: 1.05rem; color: var(--navy); margin-bottom: 0.35rem; }
  .wf-step p  { font-size: 0.84rem; color: var(--text-muted); line-height: 1.6; }

  /* ── TABLE ── */
  .table-wrap { overflow-x: auto; border-radius: 12px; border: 1.5px solid var(--border); margin-top: 1.5rem; }
  .prompt-table { width: 100%; border-collapse: collapse; font-size: 0.86rem; min-width: 520px; }
  .prompt-table th {
    background: var(--navy); color: var(--gold);
    font-family: 'DM Serif Display', serif; font-size: 0.92rem; font-weight: 400;
    padding: 0.78rem 1rem; text-align: left; letter-spacing: 0.03em;
  }
  .prompt-table td {
    padding: 0.78rem 1rem; border-bottom: 1px solid var(--border);
    vertical-align: top; line-height: 1.55;
  }
  .prompt-table tr:last-child td { border-bottom: none; }
  .prompt-table tr:nth-child(even) td { background: var(--off-white); }
  .prompt-table td:first-child { font-weight: 600; color: var(--navy); white-space: nowrap; }

  /* ── PROMPT CARDS ── */
  .prompt-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.2rem; margin-top: 1.6rem; }
  .prompt-card {
    background: var(--navy); border-radius: 12px; padding: 1.5rem; position: relative; overflow: hidden;
  }
  .prompt-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--gold); }
  .prompt-card .pl { font-size: 0.63rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.55rem; display: block; }
  .prompt-card h3 { font-family: 'DM Serif Display', serif; font-size: 1rem; color: var(--white); margin-bottom: 0.8rem; }
  .prompt-text {
    background: rgba(255,255,255,0.06); border-left: 3px solid var(--gold);
    border-radius: 0 6px 6px 0; padding: 0.75rem 0.85rem;
    font-size: 0.82rem; color: var(--pale-navy); font-style: italic; line-height: 1.65;
  }
  .prompt-text strong { color: var(--gold-light); font-style: normal; }

  /* ── CHEAT SHEET ── */
  .cheat-box {
    background: var(--gold-pale); border: 2px solid var(--gold);
    border-radius: 12px; padding: 1.6rem 1.75rem; margin-top: 1.75rem;
  }
  .cheat-box h3 {
    font-family: 'DM Serif Display', serif; font-size: 1.15rem; color: var(--navy);
    margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;
  }
  .cheat-rows { display: flex; flex-direction: column; gap: 0.7rem; }
  .cheat-row {
    background: var(--white); border: 1px solid var(--border); border-radius: 8px;
    padding: 0.8rem 1rem; display: grid; grid-template-columns: 125px 1fr;
    gap: 0.9rem; align-items: start; font-size: 0.86rem;
  }
  .step-name { font-weight: 700; color: var(--navy); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.07em; padding-top: 0.1rem; }
  .step-prompt { color: var(--text); line-height: 1.55; font-style: italic; }
  .step-prompt strong { font-style: normal; color: var(--teal); }

  /* dark cheat rows */
  .cheat-row.dr {
    background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.1);
  }
  .cheat-row.dr .step-name  { color: var(--gold-light); }
  .cheat-row.dr .step-prompt { color: var(--pale-navy); }

  /* inline dark cheat wrap */
  .dark-cheat { background: var(--navy); border-radius: 12px; padding: 1.5rem; margin-top: 1.6rem; }
  .dark-cheat h3 { font-family: 'DM Serif Display', serif; color: var(--gold); font-size: 1.05rem; margin-bottom: 0.9rem; }

  /* ── PANEL ── */
  .panel { background: var(--white); border: 1.5px solid var(--border); border-radius: 10px; padding: 1.4rem; margin-top: 1.4rem; }
  .panel h3 { font-family: 'DM Serif Display', serif; font-size: 1rem; color: var(--navy); margin-bottom: 0.7rem; }

  /* ── CHECKLIST ── */
  .checklist { list-style: none; margin-top: 0.9rem; display: flex; flex-direction: column; gap: 0.55rem; }
  .checklist li { display: flex; align-items: flex-start; gap: 0.65rem; font-size: 0.91rem; line-height: 1.55; }
  .checklist li::before { content: '✦'; color: var(--gold); font-size: 0.7rem; margin-top: 0.25rem; flex-shrink: 0; }
  .cs.dark .checklist li { color: var(--pale-navy); }

  /* ── CTA ── */
  .cta-block {
    margin-top: 2.25rem; text-align: center; padding: 2rem;
    background: rgba(252,176,64,0.1); border: 1px solid rgba(252,176,64,0.3); border-radius: 12px;
  }
  .cta-block h3 { font-family: 'DM Serif Display', serif; color: var(--gold); font-size: 1.35rem; margin-bottom: 0.6rem; }
  .cta-block p  { color: var(--pale-navy); font-size: 0.9rem; max-width: 420px; margin: 0 auto; line-height: 1.7; }

  /* ── FACILITATOR + FOOTER ── */
  .fac-bar {
    background: var(--navy); color: var(--pale-navy);
    text-align: center; padding: 1.85rem 2rem; font-size: 0.86rem; line-height: 1.8;
  }
  .fac-bar strong { color: var(--gold); }
  .fac-bar a { color: var(--gold-light); text-decoration: none; }
  .fac-bar a:hover { text-decoration: underline; }
  footer {
    background: var(--navy-dark); color: var(--text-muted);
    text-align: center; padding: 1rem 2rem; font-size: 0.73rem;
    border-top: 3px solid var(--gold);
  }

  /* ═══════════════════════════════
     RESPONSIVE BREAKPOINTS
  ═══════════════════════════════ */

  @media (max-width: 980px) {
    :root { --sidebar-w: 210px; }
    .cs { padding: 2.75rem 2rem; }
    #hero { padding: 3.25rem 2rem 3rem; }
  }

  @media (max-width: 680px) {
    /* show topbar, hide/slide sidebar */
    .topbar { display: flex; }
    .sidebar { transform: translateX(calc(-1 * var(--sidebar-w))); top: 0; }
    .sidebar.open { transform: translateX(0); }
    .main { margin-left: 0; padding-top: var(--topbar-h); }

    /* section padding */
    #hero  { padding: 2.25rem 1.25rem 2rem; }
    .cs    { padding: 2rem 1.25rem; }
    .cheat-box  { padding: 1.2rem; }
    .dark-cheat { padding: 1.2rem; }

    /* cheat rows go single-column */
    .cheat-row { grid-template-columns: 1fr; gap: 0.3rem; }

    /* workflow stack vertically */
    .workflow-grid { grid-template-columns: 1fr; }
    .wf-step { border-right: none; border-bottom: 1.5px solid var(--border); }
    .wf-step:last-child { border-bottom: none; }

    /* stats */
    .hero-stat-row { gap: 0.75rem; }
    .hero-stat { flex: 1 1 calc(50% - 0.5rem); min-width: 0; }
  }

  @media (max-width: 400px) {
    .hero-stat { flex: 1 1 100%; }
    .card-grid   { grid-template-columns: 1fr; }
    .prompt-cards { grid-template-columns: 1fr; }
  }
</style>
</head>
